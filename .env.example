# Hysteria 2 Server Configuration Template
# Copy this to .env and modify before deployment

# Domain (required — must have DNS A record pointing to VPS)
HY2_DOMAIN=sub.conanxin.com

# Listen port (UDP)
HY2_PORT=443

# Auth user
HY2_USER=conan-main

# Auth password (leave empty to auto-generate)
HY2_AUTH_PASSWORD=change-me

# Obfuscation password (leave empty to auto-generate)
HY2_OBFS_PASSWORD=change-me

# Traffic stats API secret (leave empty to auto-generate)
HY2_TRAFFIC_SECRET=change-me

# Masquerade URL (for protocol disguise)
HY2_MASQUERADE_URL=https://www.apple.com/

# Bandwidth limits
HY2_BANDWIDTH_UP=100 mbps
HY2_BANDWIDTH_DOWN=100 mbps
